{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="min-h-full relative">
    <div class="absolute inset-0 bg-gradient-to-br from-cyan-950 via-slate-950 to-blue-950"></div>
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, rgba(6, 182, 212, 0.4) 0%, transparent 40%), radial-gradient(circle at 80% 20%, rgba(59, 130, 246, 0.3) 0%, transparent 40%), radial-gradient(circle at 50% 80%, rgba(139, 92, 246, 0.2) 0%, transparent 40%);"></div>

    <div class="relative z-10">
        <nav class="border-b border-slate-800 bg-slate-900 bg-opacity-40">
            <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center shadow-lg">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                        </svg>
                    </div>
                    <span class="text-lg font-bold bg-gradient-to-r from-cyan-300 to-blue-400 bg-clip-text text-transparent">Prism</span>
                    <span class="text-xs font-mono text-slate-500 hidden sm:inline bg-slate-800 px-2.5 py-1 rounded-full">v1.0.0</span>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-slate-400 hidden sm:inline font-mono">{{ app.user.userIdentifier }}</span>
                    <a href="{{ path('app_logout') }}" class="text-sm text-slate-400 hover:text-cyan-300 transition-colors font-medium">Sign Out</a>
                </div>
            </div>
        </nav>

        <div class="max-w-7xl mx-auto px-6 py-10">
            <div class="mb-10">
                <h1 class="text-3xl font-bold text-white mb-2">MCP Servers</h1>
                <p class="text-slate-400">{{ servers|length }} server{{ servers|length != 1 ? 's' : '' }} configured &middot; {{ totalTools }} tool{{ totalTools != 1 ? 's' : '' }} registered</p>
            </div>

            {% if servers is not empty %}
            <div class="grid gap-8 sm:grid-cols-2">
                {% for server in servers %}
                <a href="{{ path('admin_server', {serverName: server.name}) }}" class="group bg-slate-900 border border-slate-800 hover:border-cyan-800 rounded-2xl p-8 transition-all duration-300 block">
                    <div class="flex items-start justify-between mb-5">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet-600 to-cyan-600 flex items-center justify-center">
                                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" />
                                </svg>
                            </div>
                            <div>
                                <h2 class="text-lg font-bold text-white group-hover:text-cyan-300 transition-colors">{{ server.label }}</h2>
                                <span class="text-xs font-mono text-slate-500">{{ server.name }}</span>
                            </div>
                        </div>
                        <span class="inline-flex items-center gap-1.5 text-xs font-mono text-emerald-400 bg-emerald-950 px-3 py-1.5 rounded-lg">
                            <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                            active
                        </span>
                    </div>

                    <div class="mb-5">
                        <code class="text-xs text-cyan-300 bg-slate-800 rounded-lg px-3.5 py-2 font-mono break-all inline-block">{{ server.mcpUrl }}</code>
                    </div>

                    <div class="flex items-center gap-5 text-sm text-slate-400">
                        <span class="flex items-center gap-1.5">
                            <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Zm6-10.125a1.875 1.875 0 1 1-3.75 0 1.875 1.875 0 0 1 3.75 0Zm1.294 6.336a6.721 6.721 0 0 1-3.17.789 6.721 6.721 0 0 1-3.168-.789 3.376 3.376 0 0 1 6.338 0Z" /></svg>
                            {{ server.accountCount }} account{{ server.accountCount != 1 ? 's' : '' }}
                        </span>
                        <span class="flex items-center gap-1.5">
                            <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" /></svg>
                            {{ server.toolCount }} tool{{ server.toolCount != 1 ? 's' : '' }}
                        </span>
                    </div>

                    {% if server.typeCounts is not empty %}
                    <div class="flex flex-wrap gap-2 mt-5">
                        {% for type, count in server.typeCounts %}
                        <span class="font-mono text-xs font-semibold text-violet-300 bg-violet-950 px-3 py-1.5 rounded-lg">{{ type }} &times; {{ count }}</span>
                        {% endfor %}
                    </div>
                    {% endif %}

                    <div class="mt-5 flex items-center gap-1 text-xs text-slate-500 group-hover:text-cyan-400 transition-colors">
                        <span>View details</span>
                        <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                    </div>
                </a>
                {% endfor %}
            </div>
            {% else %}
            <div class="text-center py-16 text-slate-500">
                <p class="text-lg font-medium">No servers configured</p>
                <p class="text-sm mt-1">Add servers to <code class="text-cyan-400">prism.config.yaml</code>.</p>
            </div>
            {% endif %}

            <div class="mt-16 pt-8 border-t border-slate-800 text-center">
                <p class="text-xs text-slate-600 font-mono">Prism &bull; MCP Protocol v2024-11-05 &bull; Built with Symfony</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
