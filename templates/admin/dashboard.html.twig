{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="min-h-full relative">
    <div class="absolute inset-0 bg-gradient-to-br from-cyan-950 via-slate-950 to-blue-950"></div>
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, rgba(6, 182, 212, 0.4) 0%, transparent 40%), radial-gradient(circle at 80% 20%, rgba(59, 130, 246, 0.3) 0%, transparent 40%), radial-gradient(circle at 50% 80%, rgba(139, 92, 246, 0.2) 0%, transparent 40%);"></div>

    <div class="relative z-10">
        {# Top navigation #}
        <nav class="border-b border-slate-800/50 bg-slate-900/40 backdrop-blur-xl">
            <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center shadow-lg shadow-cyan-500/20">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                        </svg>
                    </div>
                    <span class="text-lg font-bold bg-gradient-to-r from-cyan-300 to-blue-400 bg-clip-text text-transparent">Joost Bridge</span>
                    <span class="text-xs font-mono text-slate-500 hidden sm:inline border border-slate-700 px-2 py-0.5 rounded-full">v1.0.0</span>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-slate-400 hidden sm:inline font-mono">{{ app.user.userIdentifier }}</span>
                    <a href="{{ path('app_logout') }}" class="text-sm text-slate-400 hover:text-cyan-300 transition-colors font-medium">Sign Out</a>
                </div>
            </div>
        </nav>

        <div class="max-w-7xl mx-auto px-6 py-10">
            {# Header #}
            <div class="mb-10">
                <h1 class="text-3xl font-bold text-white mb-2">MCP Tool Registry</h1>
                <p class="text-slate-400">{{ tools|length }} tool{{ tools|length != 1 ? 's' : '' }} registered and ready to bridge.</p>
            </div>

            {# Connection info #}
            <div class="mb-10 bg-slate-900/60 backdrop-blur border border-slate-700/40 rounded-2xl p-6">
                <h2 class="text-sm font-semibold text-cyan-400 uppercase tracking-wider mb-4 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>
                    Connection
                </h2>
                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label class="block text-xs text-slate-500 mb-1 font-mono">MCP Endpoint</label>
                        <code class="block text-sm text-cyan-300 bg-slate-800/50 border border-slate-700/50 rounded-lg px-4 py-2.5 font-mono break-all">{{ mcpUrl }}</code>
                    </div>
                    <div>
                        <label class="block text-xs text-slate-500 mb-1 font-mono">Auth Header</label>
                        <code class="block text-sm text-blue-300 bg-slate-800/50 border border-slate-700/50 rounded-lg px-4 py-2.5 font-mono">Authorization: Bearer &lt;token&gt;</code>
                    </div>
                </div>
                <div class="mt-4">
                    <label class="block text-xs text-slate-500 mb-1 font-mono">Cursor .mcp.json</label>
                    <pre class="text-sm text-emerald-300 bg-slate-800/50 border border-slate-700/50 rounded-lg px-4 py-2.5 font-mono overflow-x-auto">{
  "mcpServers": {
    "joost-bridge": {
      "url": "{{ mcpUrl }}",
      "headers": {
        "Authorization": "Bearer YOUR_TOKEN_HERE"
      }
    }
  }
}</pre>
                </div>
            </div>

            {# Tools grid #}
            <div class="space-y-6">
                {% for tool in tools %}
                <div class="group bg-slate-900/60 backdrop-blur border border-slate-700/40 hover:border-cyan-500/30 rounded-2xl p-6 transition-all duration-300 hover:shadow-lg hover:shadow-cyan-900/10">
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-cyan-500/20 to-blue-500/20 border border-cyan-500/20 flex items-center justify-center group-hover:from-cyan-500/30 group-hover:to-blue-500/30 transition-all">
                                <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-white font-mono">{{ tool.name }}</h3>
                            </div>
                        </div>
                        <span class="inline-flex items-center gap-1.5 text-xs font-mono text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-3 py-1 rounded-full">
                            <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                            active
                        </span>
                    </div>

                    <p class="text-slate-300 text-sm mb-5 leading-relaxed">{{ tool.description }}</p>

                    {% set schema = tool.inputSchema %}
                    {% if schema.properties is defined and schema.properties is not empty %}
                    <div>
                        <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3 flex items-center gap-2">
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" /></svg>
                            Parameters
                        </h4>
                        <div class="bg-slate-800/30 border border-slate-700/30 rounded-xl overflow-hidden">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="border-b border-slate-700/30">
                                        <th class="text-left px-4 py-2.5 text-slate-500 font-mono text-xs font-medium">Name</th>
                                        <th class="text-left px-4 py-2.5 text-slate-500 font-mono text-xs font-medium">Type</th>
                                        <th class="text-left px-4 py-2.5 text-slate-500 font-mono text-xs font-medium">Required</th>
                                        <th class="text-left px-4 py-2.5 text-slate-500 font-mono text-xs font-medium">Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for propName, prop in schema.properties %}
                                    <tr class="border-b border-slate-700/20 last:border-0">
                                        <td class="px-4 py-2.5 font-mono text-cyan-300 text-xs">{{ propName }}</td>
                                        <td class="px-4 py-2.5">
                                            <span class="font-mono text-xs text-violet-300 bg-violet-500/10 border border-violet-500/20 px-2 py-0.5 rounded">
                                                {{ prop.type }}{% if prop.items is defined %}[{{ prop.items.type }}]{% endif %}
                                            </span>
                                        </td>
                                        <td class="px-4 py-2.5">
                                            {% if schema.required is defined and propName in schema.required %}
                                                <span class="text-xs text-amber-400 font-mono">required</span>
                                            {% else %}
                                                <span class="text-xs text-slate-600 font-mono">optional</span>
                                            {% endif %}
                                        </td>
                                        <td class="px-4 py-2.5 text-slate-400 text-xs">{{ prop.description|default('—') }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    {% endif %}

                    {# Example JSON-RPC call #}
                    <details class="mt-4 group/details">
                        <summary class="cursor-pointer text-xs font-mono text-slate-500 hover:text-cyan-400 transition-colors select-none flex items-center gap-1">
                            <svg class="w-3.5 h-3.5 transition-transform group-open/details:rotate-90" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                            Example curl
                        </summary>
                        <pre class="mt-2 text-xs text-blue-200 bg-slate-800/50 border border-slate-700/30 rounded-lg px-4 py-3 font-mono overflow-x-auto">curl -X POST {{ mcpUrl }} \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_TOKEN" \
  -d '{
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/call",
    "params": {
      "name": "{{ tool.name }}",
      "arguments": { {% for propName, prop in schema.properties %}{% if not loop.first %}, {% endif %}"{{ propName }}": ...{% endfor %} }
    }
  }'</pre>
                    </details>
                </div>
                {% else %}
                <div class="text-center py-16 text-slate-500">
                    <svg class="w-16 h-16 mx-auto mb-4 text-slate-700" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" /></svg>
                    <p class="text-lg font-medium">No tools registered yet</p>
                    <p class="text-sm mt-1">Implement <code class="text-cyan-400">ToolInterface</code> to add tools.</p>
                </div>
                {% endfor %}
            </div>

            {# Footer #}
            <div class="mt-16 pt-8 border-t border-slate-800/50 text-center">
                <p class="text-xs text-slate-600 font-mono">Joost Bridge &bull; MCP Protocol v2024-11-05 &bull; Built with Symfony</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
