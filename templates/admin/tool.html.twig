{% extends 'base.html.twig' %}

{% block title %}{{ tool.name }} — {{ server.label }}{% endblock %}

{% block body %}
<div class="min-h-full relative">
    <div class="absolute inset-0 bg-gradient-to-br from-cyan-950 via-slate-950 to-blue-950"></div>
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, rgba(6, 182, 212, 0.4) 0%, transparent 40%), radial-gradient(circle at 80% 20%, rgba(59, 130, 246, 0.3) 0%, transparent 40%), radial-gradient(circle at 50% 80%, rgba(139, 92, 246, 0.2) 0%, transparent 40%);"></div>

    <div class="relative z-10">
        <nav class="border-b border-slate-800 bg-slate-900 bg-opacity-40">
            <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <a href="{{ path('admin_dashboard') }}" class="w-9 h-9 rounded-lg bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center shadow-lg">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                        </svg>
                    </a>
                    <a href="{{ path('admin_dashboard') }}" class="text-lg font-bold bg-gradient-to-r from-cyan-300 to-blue-400 bg-clip-text text-transparent">Prism</a>
                    <svg class="w-4 h-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                    <a href="{{ path('admin_server_tab', {serverName: server.name, tab: 'tools'}) }}" class="text-sm font-medium text-slate-400 hover:text-cyan-300 transition-colors">{{ server.name }}</a>
                    <svg class="w-4 h-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                    <span class="text-sm font-medium text-slate-300 font-mono">{{ tool.name }}</span>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-slate-400 hidden sm:inline font-mono">{{ app.user.userIdentifier }}</span>
                    <a href="{{ path('app_logout') }}" class="text-sm text-slate-400 hover:text-cyan-300 transition-colors font-medium">Sign Out</a>
                </div>
            </div>
        </nav>

        <div class="max-w-7xl mx-auto px-6 py-10">
            {# Breadcrumb #}
            <div class="flex items-center gap-2 mb-8">
                <a href="{{ path('admin_server_tab', {serverName: server.name, tab: 'tools'}) }}" class="text-xs text-slate-500 hover:text-cyan-400 transition-colors font-mono flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
                    {{ server.name }} / tools
                </a>
            </div>

            {# Tool header #}
            <div class="flex items-start gap-4 mb-10">
                <div class="w-14 h-14 rounded-xl bg-cyan-950 flex items-center justify-center flex-shrink-0">
                    <svg class="w-7 h-7 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-white font-mono">{{ tool.name }}</h1>
                    <p class="text-slate-400 text-sm mt-1.5 leading-relaxed max-w-2xl">{{ tool.description }}</p>
                    {% if tool.accountType %}
                    <span class="inline-block text-xs font-mono font-semibold text-violet-300 bg-violet-950 px-3.5 py-1.5 rounded-lg mt-3">{{ tool.accountType }}</span>
                    {% endif %}
                </div>
            </div>

            <div class="grid gap-8 lg:grid-cols-2">
                {# Left column: Schema #}
                <div class="space-y-8">
                    {# Input Schema YAML #}
                    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8">
                        <h2 class="text-sm font-semibold text-cyan-400 uppercase tracking-wider mb-5">Input Schema</h2>
                        <pre class="text-xs text-cyan-200 bg-slate-800 rounded-xl px-5 py-4 font-mono overflow-x-auto whitespace-pre-wrap">{{ tool.inputSchemaYaml }}</pre>
                    </div>

                    {# Parameters table #}
                    {% if tool.inputSchema.properties is defined and tool.inputSchema.properties is iterable and tool.inputSchema.properties is not empty %}
                    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8">
                        <h2 class="text-sm font-semibold text-cyan-400 uppercase tracking-wider mb-5">Parameters</h2>
                        <div class="bg-slate-800 rounded-xl overflow-hidden">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="border-b border-slate-700">
                                        <th class="text-left px-5 py-3 text-slate-500 font-mono text-xs font-medium">Name</th>
                                        <th class="text-left px-5 py-3 text-slate-500 font-mono text-xs font-medium">Type</th>
                                        <th class="text-left px-5 py-3 text-slate-500 font-mono text-xs font-medium">Required</th>
                                        <th class="text-left px-5 py-3 text-slate-500 font-mono text-xs font-medium">Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for propName, prop in tool.inputSchema.properties %}
                                    <tr class="border-b border-slate-700 last:border-0">
                                        <td class="px-5 py-3 font-mono text-cyan-300 text-xs">{{ propName }}</td>
                                        <td class="px-5 py-3">
                                            <span class="font-mono text-xs text-violet-300 bg-violet-950 px-2.5 py-1 rounded">
                                                {{ prop.type }}{% if prop.items is defined %}[{{ prop.items.type }}]{% endif %}
                                            </span>
                                        </td>
                                        <td class="px-5 py-3">
                                            {% if tool.inputSchema.required is defined and propName in tool.inputSchema.required %}
                                                <span class="text-xs text-amber-400 font-mono">required</span>
                                            {% else %}
                                                <span class="text-xs text-slate-600 font-mono">optional</span>
                                            {% endif %}
                                        </td>
                                        <td class="px-5 py-3 text-slate-400 text-xs">{{ prop.description|default('—') }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    {% endif %}
                </div>

                {# Right column: Try it #}
                <div>
                    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8">
                        <h2 class="text-sm font-semibold text-cyan-400 uppercase tracking-wider mb-5">Try It</h2>
                        <div class="space-y-5">
                            <div>
                                <label class="block text-xs text-slate-500 mb-2 font-mono">Arguments (YAML)</label>
                                <textarea id="tool-input" class="w-full h-44 bg-slate-800 border border-slate-700 rounded-lg px-5 py-4 text-sm text-cyan-200 font-mono placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 resize-y"
                                    placeholder="# Enter YAML arguments..."
                                    spellcheck="false">{{ tool.sampleArgs }}</textarea>
                            </div>
                            <div class="flex items-center gap-3">
                                <button type="button" id="tool-execute-btn"
                                    class="px-6 py-2.5 bg-gradient-to-r from-cyan-500 to-blue-500 hover:from-cyan-400 hover:to-blue-400 text-white text-sm font-semibold rounded-lg shadow-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-cyan-400 flex items-center gap-2 cursor-pointer">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" /></svg>
                                    Execute
                                </button>
                                <span id="tool-status" class="text-xs font-mono text-slate-600 hidden"></span>
                            </div>
                            <div id="tool-response-box" class="hidden">
                                <label class="block text-xs text-slate-500 mb-2 font-mono">Response (YAML)</label>
                                <pre id="tool-response-output" class="text-xs bg-slate-800 rounded-lg px-5 py-4 font-mono overflow-x-auto whitespace-pre-wrap max-h-96 overflow-y-auto"></pre>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-16 pt-8 border-t border-slate-800 text-center">
                <p class="text-xs text-slate-600 font-mono">Prism &bull; MCP Protocol v2024-11-05 &bull; Built with Symfony</p>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    var btn = document.getElementById('tool-execute-btn');
    var input = document.getElementById('tool-input');
    var responseBox = document.getElementById('tool-response-box');
    var responseOutput = document.getElementById('tool-response-output');
    var statusEl = document.getElementById('tool-status');
    var executeUrl = {{ path('admin_tool_execute', {serverName: server.name, toolName: tool.name})|json_encode|raw }};

    btn.addEventListener('click', function() {
        btn.disabled = true;
        btn.classList.add('opacity-60');
        statusEl.textContent = 'Executing...';
        statusEl.classList.remove('hidden', 'text-red-400', 'text-emerald-400');
        statusEl.classList.add('text-slate-400');

        fetch(executeUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'text/yaml' },
            body: input.value
        })
        .then(function(resp) { return resp.json(); })
        .then(function(data) {
            responseBox.classList.remove('hidden');
            responseOutput.textContent = data.yaml || '# Empty response';
            if (data.isError) {
                responseOutput.className = 'text-xs bg-slate-800 rounded-lg px-5 py-4 font-mono overflow-x-auto whitespace-pre-wrap max-h-96 overflow-y-auto text-red-300';
                statusEl.textContent = 'Error';
                statusEl.classList.remove('text-slate-400');
                statusEl.classList.add('text-red-400');
            } else {
                responseOutput.className = 'text-xs bg-slate-800 rounded-lg px-5 py-4 font-mono overflow-x-auto whitespace-pre-wrap max-h-96 overflow-y-auto text-emerald-200';
                statusEl.textContent = 'Success';
                statusEl.classList.remove('text-slate-400');
                statusEl.classList.add('text-emerald-400');
            }
        })
        .catch(function(err) {
            responseBox.classList.remove('hidden');
            responseOutput.textContent = '# Network error: ' + err.message;
            responseOutput.className = 'text-xs bg-slate-800 rounded-lg px-5 py-4 font-mono overflow-x-auto whitespace-pre-wrap max-h-96 overflow-y-auto text-red-300';
            statusEl.textContent = 'Failed';
            statusEl.classList.remove('text-slate-400');
            statusEl.classList.add('text-red-400');
        })
        .finally(function() {
            btn.disabled = false;
            btn.classList.remove('opacity-60');
        });
    });
})();
</script>
{% endblock %}
