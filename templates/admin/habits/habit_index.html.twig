{% extends 'admin/server_base.html.twig' %}

{% block title %}Habit definitions — {{ server.label }}{% endblock %}

{% block server_page_header %}
            <div class="mb-6 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
                <div>
                    <div class="flex items-center gap-2 mb-2">
                        <a href="{{ path('admin_server_habits', {serverName: server.name}) }}" class="text-xs text-slate-500 hover:text-cyan-400 font-mono">Habits</a>
                        <span class="text-slate-600">/</span>
                        <span class="text-xs font-mono text-slate-500">definitions</span>
                    </div>
                    <h1 class="text-2xl font-bold text-white">Habit definitions</h1>
                    <p class="text-slate-400 text-sm mt-1">{{ habits|length }} habit{{ habits|length != 1 ? 's' : '' }}</p>
                </div>
                <a href="{{ path('admin_server_habits_goals_new', {serverName: server.name}) }}" class="inline-flex items-center justify-center gap-2 bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors shrink-0">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                    New habit
                </a>
            </div>
{% endblock %}

{% block server_main %}
            {% include 'admin/habits/_subnav.html.twig' with { habitsSubnav: 'goals' } %}

            {% for message in app.flashes('success') %}
            <div class="mb-6 rounded-xl border border-emerald-800/60 bg-emerald-950/40 px-4 py-3 text-sm text-emerald-200">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
            <div class="mb-6 rounded-xl border border-red-800/60 bg-red-950/40 px-4 py-3 text-sm text-red-200">{{ message }}</div>
            {% endfor %}

            {% if habits is empty %}
            <div class="rounded-2xl border border-slate-800 bg-slate-900/50 px-8 py-12 text-center text-slate-500 text-sm">
                No habits yet. Use <strong class="text-slate-400">New habit</strong> or MCP <code class="text-xs text-cyan-600/90">habits_create_habit</code>.
            </div>
            {% else %}
            <div class="rounded-2xl border border-slate-800 overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-slate-900/90 border-b border-slate-800 text-left text-xs font-semibold uppercase tracking-wider text-slate-500">
                            <th class="px-4 py-3">Title</th>
                            <th class="px-4 py-3">Slug</th>
                            <th class="px-4 py-3 hidden sm:table-cell">Goal</th>
                            <th class="px-4 py-3 hidden lg:table-cell">Members</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3 w-28"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800/80">
                        {% for h in habits %}
                        <tr class="bg-slate-900/40 hover:bg-slate-800/30 transition-colors">
                            <td class="px-4 py-3 font-medium text-slate-100">{{ h.title }}</td>
                            <td class="px-4 py-3 font-mono text-slate-400 text-xs">{{ h.slug }}</td>
                            <td class="px-4 py-3 hidden sm:table-cell text-slate-500 text-xs font-mono">{{ h.goal_mode }}</td>
                            <td class="px-4 py-3 hidden lg:table-cell text-slate-500 text-xs">{{ h.members|length }}</td>
                            <td class="px-4 py-3">{% if h.active %}<span class="text-emerald-400/90 text-xs">active</span>{% else %}<span class="text-slate-500 text-xs">inactive</span>{% endif %}</td>
                            <td class="px-4 py-3">
                                <a href="{{ path('admin_server_habits_goals_edit', {serverName: server.name, habitXuid: h.xuid}) }}" class="text-cyan-400 hover:text-cyan-300 text-xs font-semibold">Edit</a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}
{% endblock %}
