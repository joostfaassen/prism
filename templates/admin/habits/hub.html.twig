{% extends 'admin/server_base.html.twig' %}

{% block title %}Habits — {{ server.label }}{% endblock %}

{% block server_page_header %}
            <div class="mb-6">
                <div class="flex items-center gap-2 mb-3">
                    <a href="{{ path('admin_dashboard') }}" class="text-xs text-slate-500 hover:text-cyan-400 transition-colors font-mono flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
                        All servers
                    </a>
                </div>
                <h1 class="text-2xl font-bold text-white">Habits</h1>
                <p class="text-slate-400 text-sm mt-1">Users, habit definitions, REST ingest, and MCP tools for <span class="font-mono text-slate-300">{{ server.name }}</span></p>
            </div>
{% endblock %}

{% block server_main %}
            {% include 'admin/habits/_subnav.html.twig' with { habitsSubnav: 'hub' } %}

            {% for message in app.flashes('success') %}
            <div class="mb-6 rounded-xl border border-emerald-800/60 bg-emerald-950/40 px-4 py-3 text-sm text-emerald-200">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
            <div class="mb-6 rounded-xl border border-red-800/60 bg-red-950/40 px-4 py-3 text-sm text-red-200">{{ message }}</div>
            {% endfor %}

            {% if not serverHasHabits %}
            <div class="rounded-2xl border border-amber-800/50 bg-amber-950/20 px-6 py-8 text-center">
                <p class="text-slate-300 text-sm mb-4">Add a <span class="font-mono text-amber-200/90">habits</span> account under this server in <code class="text-xs bg-slate-800 px-2 py-1 rounded">prism.config.yaml</code> to enable the habits UI, REST API, and MCP tools.</p>
                <a href="{{ path('admin_server_tab', {serverName: server.name, tab: 'accounts'}) }}" class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-400 hover:text-cyan-300">View accounts →</a>
            </div>
            {% else %}
            <p class="text-sm text-slate-500 mb-6">REST base URL (Bearer <span class="font-mono text-slate-400">rest_ingest_token</span>):<br><code class="mt-2 inline-block text-xs bg-slate-800 px-3 py-2 rounded text-cyan-300/90 break-all">{{ restBaseUrl }}</code></p>

            <div class="grid gap-6 sm:grid-cols-2">
                <a href="{{ path('admin_server_habits_users', {serverName: server.name}) }}" class="group rounded-2xl border border-slate-800 bg-slate-900/80 p-6 hover:border-cyan-800/60 hover:bg-slate-900 transition-all">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="w-10 h-10 rounded-xl bg-slate-800 flex items-center justify-center text-cyan-400 group-hover:bg-cyan-950/50">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.433-2.554A9.375 9.375 0 0 0 12 21.75c-1.314 0-2.569-.268-3.704-.75a4.125 4.125 0 0 0-7.433 2.554A9.375 9.375 0 0 0 12 21.75c4.314 0 7.813-2.851 9.106-6.75Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 7.5A2.25 2.25 0 1 1 15.75 7.5 2.25 2.25 0 0 1 11.25 7.5Z" /></svg>
                        </span>
                        <h2 class="text-lg font-semibold text-white group-hover:text-cyan-200">Habit users</h2>
                    </div>
                    <p class="text-sm text-slate-500">List, add, and edit participants (username, display name, YAML).</p>
                    <span class="mt-4 inline-flex items-center gap-1 text-xs font-medium text-cyan-500 group-hover:text-cyan-400">Open →</span>
                </a>
                <a href="{{ path('admin_server_habits_goals', {serverName: server.name}) }}" class="group rounded-2xl border border-slate-800 bg-slate-900/80 p-6 hover:border-cyan-800/60 hover:bg-slate-900 transition-all">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="w-10 h-10 rounded-xl bg-slate-800 flex items-center justify-center text-amber-300/90 group-hover:bg-amber-950/30">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>
                        </span>
                        <h2 class="text-lg font-semibold text-white group-hover:text-cyan-200">Habit definitions</h2>
                    </div>
                    <p class="text-sm text-slate-500">Goals, scoring, members, and check-in settings per habit.</p>
                    <span class="mt-4 inline-flex items-center gap-1 text-xs font-medium text-cyan-500 group-hover:text-cyan-400">Open →</span>
                </a>
            </div>
            {% endif %}
{% endblock %}
