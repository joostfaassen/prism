{% extends 'admin/server_base.html.twig' %}

{% block title %}{{ document.name }} — {{ server.label }}{% endblock %}

{% block server_page_header %}
            <div class="mb-8">
                <div class="flex items-center gap-2 mb-3">
                    <a href="{{ path('admin_server_documents', {serverName: server.name}) }}" class="text-xs text-slate-500 hover:text-cyan-400 transition-colors font-mono flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
                        Documents
                    </a>
                </div>

                {# ── Summary card ─────────────────────────────────── #}
                <div class="bg-slate-900 rounded-2xl border border-slate-800 p-6">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex items-start gap-4 min-w-0">
                            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet-600 to-cyan-600 flex items-center justify-center flex-shrink-0">
                                <span class="text-lg font-bold text-white">{{ document.name|first|upper }}</span>
                            </div>
                            <div class="min-w-0">
                                <h1 class="text-xl font-bold text-white">{{ document.name }}</h1>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-xs font-mono text-amber-400 bg-amber-950 px-2 py-0.5 rounded-md">{{ document.documentType.name }}</span>
                                    <span class="text-xs text-slate-600 font-mono">{{ document.xuid }}</span>
                                </div>
                            </div>
                        </div>
                        <a href="{{ path('admin_document_edit', {serverName: server.name, xuid: document.xuid}) }}"
                           class="inline-flex items-center gap-1.5 text-xs font-semibold text-cyan-400 hover:text-cyan-300 transition-colors flex-shrink-0 mt-1">
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" /></svg>
                            Edit
                        </a>
                    </div>

                    {% if document.summary %}
                    <p class="text-sm text-slate-400 mt-4 leading-relaxed">{{ document.summary }}</p>
                    {% endif %}

                    {% if document.config %}
                    <div class="mt-4 pt-4 border-t border-slate-800">
                        <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-600 mb-2">Config</p>
                        <pre class="text-xs text-cyan-300 font-mono bg-slate-950 rounded-lg px-4 py-3 overflow-x-auto max-h-40">{{ document.config }}</pre>
                    </div>
                    {% endif %}

                    <div class="flex items-center gap-4 mt-4 pt-4 border-t border-slate-800">
                        <span class="text-xs text-slate-600">Created {{ document.createdAt|date('M j, Y') }}</span>
                        <span class="text-xs text-slate-600">Updated {{ document.updatedAt|date('M j, Y') }}</span>
                    </div>
                </div>
            </div>
{% endblock %}

{% block server_main %}
            {# ── Notes list ──────────────────────────────────────── #}
            <div class="bg-slate-900 rounded-2xl border border-slate-800 overflow-hidden">
                <div class="flex items-center justify-between px-8 py-5 border-b border-slate-800">
                    <h2 class="text-base font-semibold text-white">Notes <span class="text-slate-600 font-normal text-sm">({{ document.notes|length }})</span></h2>
                    <a href="{{ path('admin_document_note_new', {serverName: server.name, documentXuid: document.xuid}) }}"
                       class="inline-flex items-center gap-1.5 text-xs font-semibold text-cyan-400 hover:text-cyan-300 transition-colors">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                        Add note
                    </a>
                </div>

                {% if document.notes|length > 0 %}
                <div class="divide-y divide-slate-800">
                    {% for note in document.notes %}
                    <a href="{{ path('admin_document_note_edit', {serverName: server.name, documentXuid: document.xuid, noteXuid: note.xuid}) }}"
                       class="group flex items-center justify-between px-8 py-4 hover:bg-slate-800/50 transition-colors">
                        <div class="min-w-0">
                            <span class="block text-sm font-medium text-white group-hover:text-cyan-300 transition-colors">{{ note.summary }}</span>
                            <p class="text-xs text-slate-500 truncate mt-0.5 max-w-lg">{{ note.content|slice(0, 120) }}{% if note.content|length > 120 %}...{% endif %}</p>
                        </div>
                        <div class="flex items-center gap-3 flex-shrink-0 ml-4">
                            <span class="text-xs text-slate-600 font-mono">{{ note.updatedAt|date('M j, Y') }}</span>
                            <svg class="w-4 h-4 text-slate-600 group-hover:text-cyan-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                            </svg>
                        </div>
                    </a>
                    {% endfor %}
                </div>
                {% else %}
                <div class="text-center py-12">
                    <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-slate-800 mb-3">
                        <svg class="w-6 h-6 text-slate-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                        </svg>
                    </div>
                    <p class="text-sm text-slate-500 mb-4">No notes yet</p>
                    <a href="{{ path('admin_document_note_new', {serverName: server.name, documentXuid: document.xuid}) }}"
                       class="inline-flex items-center gap-1.5 text-xs font-semibold text-cyan-400 hover:text-cyan-300 transition-colors">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                        Add the first note
                    </a>
                </div>
                {% endif %}
            </div>

            {# ── Danger zone ─────────────────────────────────────── #}
            <div class="mt-8">
                <form method="post" action="{{ path('admin_document_delete', {serverName: server.name, xuid: document.xuid}) }}"
                      onsubmit="return confirm('Delete {{ document.name|e('js') }}? This will also delete all notes. This cannot be undone.')">
                    <button type="submit"
                            class="inline-flex items-center gap-2 text-sm text-red-400 hover:text-red-300 transition-colors px-4 py-2.5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>
                        Delete document
                    </button>
                </form>
            </div>
{% endblock %}
