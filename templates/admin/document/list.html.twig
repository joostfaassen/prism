{% extends 'admin/server_base.html.twig' %}

{% block title %}Documents — {{ server.label }}{% endblock %}

{% block server_page_header %}
            <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-white">Documents</h1>
                    <p class="text-slate-400 text-sm mt-1">{{ documents|length }} document{{ documents|length != 1 ? 's' : '' }}{% if typeFilter %} of type "{{ typeFilter }}"{% endif %} on {{ server.label }}</p>
                </div>
                <a href="{{ path('admin_document_new', {serverName: server.name}) }}"
                   class="inline-flex items-center justify-center gap-2 bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors shrink-0">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                    Add document
                </a>
            </div>

            {% if types|length > 1 %}
            <div class="mb-6 flex flex-wrap gap-2">
                <a href="{{ path('admin_server_documents', {serverName: server.name}) }}"
                   class="text-xs font-medium px-3 py-1.5 rounded-lg transition-colors {{ not typeFilter ? 'bg-cyan-950 text-cyan-300 border border-cyan-800' : 'bg-slate-800 text-slate-400 border border-slate-700 hover:text-slate-200' }}">All</a>
                {% for type in types %}
                <a href="{{ path('admin_server_documents', {serverName: server.name, type: type.name}) }}"
                   class="text-xs font-medium px-3 py-1.5 rounded-lg transition-colors {{ typeFilter == type.name ? 'bg-cyan-950 text-cyan-300 border border-cyan-800' : 'bg-slate-800 text-slate-400 border border-slate-700 hover:text-slate-200' }}">{{ type.name }}</a>
                {% endfor %}
            </div>
            {% endif %}
{% endblock %}

{% block server_main %}
            {% if documents is not empty %}
            <div class="space-y-3">
                {% for document in documents %}
                <a href="{{ path('admin_document_show', {serverName: server.name, xuid: document.xuid}) }}"
                   class="group flex items-center justify-between bg-slate-900 border border-slate-800 hover:border-cyan-800 rounded-xl px-6 py-5 transition-all duration-200">
                    <div class="flex items-center gap-4 min-w-0">
                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-violet-600 to-cyan-600 flex items-center justify-center flex-shrink-0">
                            <span class="text-sm font-bold text-white">{{ document.name|first|upper }}</span>
                        </div>
                        <div class="min-w-0">
                            <span class="block text-sm font-semibold text-white group-hover:text-cyan-300 transition-colors">{{ document.name }}</span>
                            {% if document.summary %}
                            <p class="text-xs text-slate-500 truncate mt-0.5 max-w-lg">{{ document.summary|slice(0, 120) }}{% if document.summary|length > 120 %}...{% endif %}</p>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex items-center gap-3 flex-shrink-0 ml-4">
                        <span class="text-xs font-mono text-amber-400 bg-amber-950 px-2.5 py-1 rounded-lg">{{ document.documentType.name }}</span>
                        {% set noteCount = document.notes|length %}
                        {% if noteCount > 0 %}
                        <span class="text-xs font-mono text-violet-400 bg-violet-950 px-2.5 py-1 rounded-lg">{{ noteCount }} note{{ noteCount != 1 ? 's' : '' }}</span>
                        {% endif %}
                        {% if document.config %}
                        <span class="text-xs font-mono text-emerald-400 bg-emerald-950 px-2.5 py-1 rounded-lg">config</span>
                        {% endif %}
                        <span class="text-xs text-slate-600 font-mono">{{ document.updatedAt|date('M j, Y') }}</span>
                        <svg class="w-4 h-4 text-slate-600 group-hover:text-cyan-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                        </svg>
                    </div>
                </a>
                {% endfor %}
            </div>
            {% else %}
            <div class="text-center py-20">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-slate-800 mb-4">
                    <svg class="w-8 h-8 text-slate-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25" />
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-slate-400 mb-2">No documents yet</h3>
                <p class="text-sm text-slate-600 max-w-md mx-auto mb-6">Add documents to organize contacts, locations, projects, and other entities.</p>
                <a href="{{ path('admin_document_new', {serverName: server.name}) }}"
                   class="inline-flex items-center gap-2 bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                    Add document
                </a>
            </div>
            {% endif %}
{% endblock %}
