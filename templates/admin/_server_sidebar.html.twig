{# Expects: server (array name, label, accountCount, toolCount), activeSection, serverHasHabits (bool), serverHasTracking (bool) #}
{% set nav_items = [
    { key: 'configuration', label: 'Configuration', route: 'admin_server_tab', route_params: {tab: 'configuration'}, icon: 'cog' },
    { key: 'accounts', label: 'Accounts', route: 'admin_server_tab', route_params: {tab: 'accounts'}, icon: 'accounts', badge: server.accountCount },
    { key: 'tools', label: 'Tools', route: 'admin_server_tab', route_params: {tab: 'tools'}, icon: 'tools', badge: server.toolCount },
    { key: 'node_types', label: 'Node Types', route: 'admin_server_node_types', route_params: {}, icon: 'tag' },
    { key: 'nodes', label: 'Nodes', route: 'admin_server_nodes', route_params: {}, icon: 'cube' },
    { key: 'habits', label: 'Habits', route: 'admin_server_habits', route_params: {}, icon: 'habits', muted: not serverHasHabits },
    { key: 'tracking', label: 'GPS', route: 'admin_tracking_home', route_params: {}, icon: 'map', muted: not serverHasTracking },
    { key: 'agents', label: 'Agent notify', route: 'admin_server_tab', route_params: {tab: 'agents'}, icon: 'agents' },
    { key: 'audit', label: 'Audit', route: 'admin_server_tab', route_params: {tab: 'audit'}, icon: 'audit' },
] %}
<nav class="lg:sticky lg:top-10 space-y-1 max-w-full" aria-label="Server sections">
    <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-600 px-3 mb-3 hidden lg:block">This server</p>
    {% for item in nav_items %}
        {% set is_active = activeSection == item.key %}
        {% set href = path(item.route, { serverName: server.name }|merge(item.route_params)) %}
        <a href="{{ href }}"
           {% if item.muted|default(false) %}title="{% if item.key == 'habits' %}Add a habits-type account in Accounts to enable habits tools for this server.{% elseif item.key == 'tracking' %}Add a tracking-type account in prism.config.yaml to enable GPS MCP tools and these pages.{% else %}Enable the related account type for this server.{% endif %}"{% endif %}
           class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium transition-all duration-200 border
                  {% if is_active %}
                      border-cyan-800/80 bg-cyan-950/50 text-cyan-200 shadow-sm
                  {% elseif item.muted|default(false) %}
                      border-transparent text-slate-400/90 hover:text-slate-200 hover:bg-slate-800/50 opacity-95
                  {% else %}
                      border-transparent text-slate-400 hover:text-slate-200 hover:bg-slate-800/60
                  {% endif %}">
            <span class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center
                {% if is_active %}bg-cyan-900/80 text-cyan-300{% else %}bg-slate-800 text-slate-500{% endif %}">
                {% if item.icon == 'cog' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                {% elseif item.icon == 'accounts' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Zm6-10.125a1.875 1.875 0 1 1-3.75 0 1.875 1.875 0 0 1 3.75 0Zm1.294 6.336a6.721 6.721 0 0 1-3.17.789 6.721 6.721 0 0 1-3.168-.789 3.376 3.376 0 0 1 6.338 0Z" /></svg>
                {% elseif item.icon == 'tools' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" /></svg>
                {% elseif item.icon == 'tag' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" /></svg>
                {% elseif item.icon == 'cube' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>
                {% elseif item.icon == 'habits' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>
                {% elseif item.icon == 'agents' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                {% elseif item.icon == 'audit' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" /></svg>
                {% elseif item.icon == 'map' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
                {% endif %}
            </span>
            <span class="flex-1 min-w-0 text-left flex items-center gap-2 flex-wrap">
                {{ item.label }}
                {% if item.muted|default(false) and (item.key == 'habits' or item.key == 'tracking') %}
                    <span class="text-[9px] font-mono uppercase tracking-wide text-amber-500/90 shrink-0">add account</span>
                {% endif %}
            </span>
            {% if item.badge is defined %}
                <span class="text-[10px] font-mono tabular-nums px-2 py-0.5 rounded-md {% if is_active %}bg-cyan-900 text-cyan-200{% else %}bg-slate-800 text-slate-500{% endif %}">{{ item.badge }}</span>
            {% endif %}
        </a>
    {% endfor %}
</nav>
