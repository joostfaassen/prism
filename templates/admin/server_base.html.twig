{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-full relative">
    <div class="absolute inset-0 bg-gradient-to-br from-cyan-950 via-slate-950 to-blue-950"></div>
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, rgba(6, 182, 212, 0.4) 0%, transparent 40%), radial-gradient(circle at 80% 20%, rgba(59, 130, 246, 0.3) 0%, transparent 40%), radial-gradient(circle at 50% 80%, rgba(139, 92, 246, 0.2) 0%, transparent 40%);"></div>

    <div class="relative z-10">
        <nav class="border-b border-slate-800 bg-slate-900 bg-opacity-40">
            <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <a href="{{ path('admin_dashboard') }}" class="w-9 h-9 rounded-lg bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center shadow-lg">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                        </svg>
                    </a>
                    <a href="{{ path('admin_dashboard') }}" class="text-lg font-bold bg-gradient-to-r from-cyan-300 to-blue-400 bg-clip-text text-transparent">Prism</a>
                    <svg class="w-4 h-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                    <span class="text-sm font-medium text-slate-300">{{ server.name }}</span>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm text-slate-400 hidden sm:inline font-mono">{{ app.user.userIdentifier }}</span>
                    <a href="{{ path('app_logout') }}" class="text-sm text-slate-400 hover:text-cyan-300 transition-colors font-medium">Sign Out</a>
                </div>
            </div>
        </nav>

        {# Flex row: fixed-width sidebar (w-56) + flex-1 main — only standard Tailwind classes so JIT always emits CSS #}
        <div class="max-w-7xl mx-auto px-6 py-10 flex flex-col lg:flex-row lg:items-start gap-8 lg:gap-10">
            <aside class="w-full lg:w-56 lg:flex-none lg:shrink-0 lg:border-r border-slate-800/80 lg:pr-5 min-w-0 overflow-x-hidden">
                {% include 'admin/_server_sidebar.html.twig' with {
                    server: server,
                    activeSection: activeSection,
                    serverHasHabits: serverHasHabits|default(false),
                    serverHasTracking: serverHasTracking|default(false),
                } only %}
            </aside>
            <main class="w-full lg:flex-1 lg:min-w-0 min-w-0">
                {% block server_page_header %}{% endblock %}
                {% block server_main %}{% endblock %}
                <div class="mt-16 pt-8 border-t border-slate-800 text-center">
                    <p class="text-xs text-slate-600 font-mono">Prism &bull; MCP Protocol v2024-11-05 &bull; Built with Symfony</p>
                </div>
            </main>
        </div>
    </div>
</div>
{% endblock %}
