{% extends 'admin/server_base.html.twig' %}

{% block title %}Apify — {{ server.label }}{% endblock %}

{% block server_page_header %}
            <div class="mb-6">
                <div class="flex items-center gap-2 mb-3">
                    <a href="{{ path('admin_dashboard') }}" class="text-xs text-slate-500 hover:text-cyan-400 transition-colors font-mono flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
                        All servers
                    </a>
                </div>
                <h1 class="text-2xl font-bold text-white">Apify</h1>
                <p class="text-slate-400 text-sm mt-1">Apify-based MCP tools available on <span class="font-mono text-slate-300">{{ server.name }}</span> — run Apify actors and inspect their results.</p>
            </div>
{% endblock %}

{% block server_main %}
            {% if not serverHasApify %}
            <div class="mb-6 rounded-2xl border border-amber-800/50 bg-amber-950/20 px-6 py-5">
                <p class="text-slate-300 text-sm">These tools are listed for reference, but become active only once this server has an <span class="font-mono text-amber-200/90">apify</span> account. Add one (with an <span class="font-mono">api_token</span>) under this server in your prism config to enable them.</p>
                <a href="{{ path('admin_server_tab', {serverName: server.name, tab: 'accounts'}) }}" class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-400 hover:text-cyan-300 mt-3">View accounts →</a>
            </div>
            {% endif %}

            {% if apifyTools is empty %}
            <div class="rounded-2xl border border-slate-800 bg-slate-900/80 px-6 py-8 text-center text-sm text-slate-400">
                No Apify tools are registered.
            </div>
            {% else %}
            <div class="mb-4 flex items-center justify-between">
                <h2 class="text-sm font-semibold text-cyan-400 uppercase tracking-wider">Available tools</h2>
                <span class="text-[10px] font-mono tabular-nums px-2 py-0.5 rounded-md bg-slate-800 text-slate-400">{{ apifyTools|length }}</span>
            </div>
            <div class="space-y-3">
                {% for tool in apifyTools %}
                <div class="rounded-2xl border bg-slate-900/80 p-5 {% if tool.enabled %}border-slate-800{% else %}border-slate-800/60 opacity-60{% endif %}">
                    <div class="flex items-center gap-3 mb-1.5 flex-wrap">
                        <h3 class="text-sm font-semibold text-white font-mono">{{ tool.name }}</h3>
                        {% if tool.isActor %}
                        <span class="text-[10px] font-mono uppercase tracking-wide px-2 py-0.5 rounded-md bg-violet-950/60 text-violet-300 border border-violet-800/60">actor</span>
                        {% else %}
                        <span class="text-[10px] font-mono uppercase tracking-wide px-2 py-0.5 rounded-md bg-slate-800 text-slate-400 border border-slate-700">utility</span>
                        {% endif %}
                        {% if tool.enabled %}
                        <span class="text-[10px] font-mono uppercase tracking-wide px-2 py-0.5 rounded-md bg-emerald-950/60 text-emerald-300 border border-emerald-800/60">exposed</span>
                        {% else %}
                        <span class="text-[10px] font-mono uppercase tracking-wide px-2 py-0.5 rounded-md bg-slate-800 text-slate-500 border border-slate-700">not exposed</span>
                        {% endif %}
                    </div>
                    <p class="text-sm text-slate-400 leading-relaxed">{{ tool.description }}</p>
                </div>
                {% endfor %}
            </div>

            <p class="text-xs text-slate-600 mt-6">Restrict which tools are exposed by adding a <span class="font-mono text-slate-400">tools:</span> allowlist to the <span class="font-mono text-slate-400">apify</span> account in your prism config (supports wildcards, e.g. <span class="font-mono text-slate-400">apify_get_*</span>). Omit it to expose all. Add new actor-backed tools by extending <code class="text-slate-400">App\Mcp\Tool\Apify\AbstractApifyActorTool</code>; use <span class="font-mono text-slate-400">apify_get_actor</span> to inspect an actor first.</p>
            {% endif %}
{% endblock %}
