{% extends 'admin/server_base.html.twig' %}

{% block title %}Zone check-in/out — {{ server.label }}{% endblock %}

{% block server_page_header %}
            <div class="mb-8">
                <div class="flex items-center gap-2 mb-2">
                    <a href="{{ path('admin_tracking_home', {serverName: server.name}) }}" class="text-xs text-slate-500 hover:text-cyan-400 font-mono">GPS</a>
                    <span class="text-slate-600">/</span>
                    <span class="text-xs font-mono text-slate-500">zone log</span>
                </div>
                <h1 class="text-2xl font-bold text-white">Zone events</h1>
                <p class="text-slate-400 text-sm mt-1">Enter and exit times per location · times use <span class="font-mono text-slate-300">{{ timezoneName }}</span> for day boundaries on the map; this form uses the raw ISO range you enter.</p>
            </div>
{% endblock %}

{% block server_main %}
            {% include 'admin/tracking/_subnav.html.twig' with { trackingSubnav: 'events' } %}

            {% for message in app.flashes('success') %}
            <div class="mb-6 rounded-xl border border-emerald-800/60 bg-emerald-950/40 px-4 py-3 text-sm text-emerald-200">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
            <div class="mb-6 rounded-xl border border-red-800/60 bg-red-950/40 px-4 py-3 text-sm text-red-200">{{ message }}</div>
            {% endfor %}

            {% if error %}
            <div class="mb-6 rounded-xl border border-red-800/60 bg-red-950/40 px-4 py-3 text-sm text-red-200">{{ error }}</div>
            {% endif %}

            <form method="get" action="{{ path('admin_tracking_zone_events', {serverName: server.name}) }}" class="mb-8 space-y-4 max-w-3xl bg-slate-900 border border-slate-800 rounded-xl p-6">
                <div>
                    <label class="block text-xs text-slate-500 mb-1 font-mono">Location</label>
                    <select name="zone_xuid" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-white">
                        <option value="">— Select —</option>
                        {% for z in zones %}
                        <option value="{{ z.xuid }}" {{ zoneXuid == z.xuid ? 'selected' }}>{{ z.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1 font-mono">Device (optional)</label>
                    <select name="device_xuid" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-white">
                        <option value="">All devices</option>
                        {% for d in devices %}
                        <option value="{{ d.xuid }}" {{ deviceXuid == d.xuid ? 'selected' }}>{{ d.label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="grid sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-slate-500 mb-1 font-mono">From (ISO)</label>
                        <input type="text" name="from" value="{{ from|e('html_attr') }}" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-white font-mono" />
                    </div>
                    <div>
                        <label class="block text-xs text-slate-500 mb-1 font-mono">To (ISO)</label>
                        <input type="text" name="to" value="{{ to|e('html_attr') }}" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-white font-mono" />
                    </div>
                </div>
                <button type="submit" class="bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold px-5 py-2 rounded-xl">Query</button>
            </form>

            <div class="mb-6">
                <h2 class="text-sm font-semibold text-slate-400 mb-2">All zone events for one day (JSON)</h2>
                <p class="text-xs text-slate-500 mb-2">GET with query <span class="font-mono text-slate-400">date=YYYY-MM-DD</span> (authenticated admin).</p>
                <code class="block text-xs text-slate-400 bg-slate-950 rounded-lg px-4 py-3 font-mono break-all">{{ app.request.schemeAndHttpHost }}{{ path('admin_tracking_api_day_events', {serverName: server.name}) }}</code>
            </div>

            {% if events is not empty %}
            <div class="overflow-x-auto rounded-xl border border-slate-800">
                <table class="min-w-full text-sm">
                    <thead class="bg-slate-900 text-left text-xs text-slate-500 uppercase tracking-wider">
                        <tr>
                            <th class="px-4 py-3">Time</th>
                            <th class="px-4 py-3">Type</th>
                            <th class="px-4 py-3">Device</th>
                            <th class="px-4 py-3">Zone</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800 bg-slate-950/40">
                        {% for e in events %}
                        <tr class="text-slate-300">
                            <td class="px-4 py-2.5 font-mono text-xs">{{ e.occurred_at }}</td>
                            <td class="px-4 py-2.5"><span class="font-mono {{ e.event_type == 'enter' ? 'text-emerald-400' : 'text-amber-400' }}">{{ e.event_type }}</span></td>
                            <td class="px-4 py-2.5">{{ e.device_label }}</td>
                            <td class="px-4 py-2.5">{{ e.zone_name }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% elseif zoneXuid %}
            <p class="text-sm text-slate-500">No events in this range.</p>
            {% endif %}
{% endblock %}
