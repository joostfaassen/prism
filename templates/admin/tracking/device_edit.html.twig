{% extends 'admin/server_base.html.twig' %}

{% block title %}{{ device ? 'Edit device' : 'New device' }} — {{ server.label }}{% endblock %}

{% block server_page_header %}
            <div class="mb-8">
                <div class="flex items-center gap-2 mb-2">
                    <a href="{{ path('admin_tracking_home', {serverName: server.name}) }}" class="text-xs text-slate-500 hover:text-cyan-400 font-mono">GPS</a>
                    <span class="text-slate-600">/</span>
                    <a href="{{ path('admin_tracking_devices', {serverName: server.name}) }}" class="text-xs text-slate-500 hover:text-cyan-400 font-mono">devices</a>
                    <span class="text-slate-600">/</span>
                    <span class="text-xs font-mono text-slate-500">{{ device ? 'edit' : 'new' }}</span>
                </div>
                <h1 class="text-2xl font-bold text-white">{{ device ? 'Edit device' : 'New device' }}</h1>
            </div>
{% endblock %}

{% block server_main %}
            {% include 'admin/tracking/_subnav.html.twig' with { trackingSubnav: 'devices' } %}

            {% for message in app.flashes('success') %}
            <div class="mb-6 rounded-xl border border-emerald-800/60 bg-emerald-950/40 px-4 py-3 text-sm text-emerald-200">{{ message }}</div>
            {% endfor %}

            {% if errors is not empty %}
            <div class="mb-6 rounded-xl border border-red-800/60 bg-red-950/40 px-4 py-3 text-sm text-red-200">
                <ul class="list-disc list-inside space-y-1">{% for e in errors %}<li>{{ e }}</li>{% endfor %}</ul>
            </div>
            {% endif %}

            <form method="post" class="max-w-2xl space-y-6">
                <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 space-y-5">
                    <div>
                        <label class="block text-xs text-slate-500 mb-2 font-mono">URL slug</label>
                        <input type="text" name="slug" value="{{ formData.slug|e('html_attr') }}" required pattern="[a-z0-9][a-z0-9_-]*"
                               class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-white font-mono focus:border-cyan-600 focus:ring-1 focus:ring-cyan-600 outline-none"
                               placeholder="example-iphone" />
                        <p class="text-[11px] text-slate-600 mt-1.5">Used in POST <span class="font-mono">/api/track/{{ server.name }}/&lt;slug&gt;</span></p>
                    </div>
                    <div>
                        <label class="block text-xs text-slate-500 mb-2 font-mono">Label</label>
                        <input type="text" name="label" value="{{ formData.label|e('html_attr') }}" required
                               class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-white focus:border-cyan-600 outline-none" placeholder="Example: work phone" />
                    </div>
                    <div>
                        <label class="block text-xs text-slate-500 mb-2 font-mono">Map color</label>
                        <input type="text" name="map_color" value="{{ formData.map_color|e('html_attr') }}"
                               class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-cyan-300 font-mono focus:border-cyan-600 outline-none" placeholder="#22d3ee" />
                    </div>
                    <div>
                        <label class="block text-xs text-slate-500 mb-2 font-mono">POST format preset</label>
                        <select name="post_format_preset" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-white focus:border-cyan-600 outline-none">
                            {% for p in ['latlng_flat','lonlat_pair','owntracks','apple_shortcuts','custom'] %}
                            <option value="{{ p }}" {{ formData.post_format_preset == p ? 'selected' }}>{{ p }}</option>
                            {% endfor %}
                        </select>
                        <p class="text-[11px] text-slate-600 mt-1.5"><span class="font-mono">latlng_flat</span>: top-level lat/lon. <span class="font-mono">lonlat_pair</span>: GeoJSON Point or coordinates array. <span class="font-mono">owntracks</span>: lat, lon, tst. <span class="font-mono">apple_shortcuts</span>: latitude, longitude. <span class="font-mono">custom</span>: JSON paths below.</p>
                    </div>
                    <div>
                        <label class="block text-xs text-slate-500 mb-2 font-mono">Custom format JSON (only for custom)</label>
                        <textarea name="post_format_json" rows="5" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-2.5 text-xs text-slate-300 font-mono focus:border-cyan-600 outline-none">{{ formData.post_format_json }}</textarea>
                    </div>
                </div>

                <div class="flex gap-3">
                    <button type="submit" class="inline-flex items-center gap-2 bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold px-5 py-2.5 rounded-xl">Save</button>
                    <a href="{{ path('admin_tracking_devices', {serverName: server.name}) }}" class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-white px-4 py-2.5">Cancel</a>
                </div>
            </form>

            {% if device %}
            <div class="max-w-2xl mt-8 bg-slate-900 border border-slate-800 rounded-xl p-6 space-y-3">
                <h2 class="text-sm font-semibold text-slate-300">Ingest credentials</h2>
                <p class="text-xs text-slate-500">Use either the server MCP bearer token or this device secret in <span class="font-mono">Authorization: Bearer …</span></p>
                <code class="block text-xs text-amber-200/90 bg-slate-950 rounded-lg px-4 py-3 font-mono break-all select-all">{{ device.ingestSecret }}</code>
                <p class="text-[11px] text-slate-600 font-mono break-all">POST {{ app.request.schemeAndHttpHost }}/api/track/{{ server.name|url_encode }}/{{ device.slug }}</p>
                <form method="post" action="{{ path('admin_tracking_device_regenerate', {serverName: server.name, xuid: device.xuid}) }}" class="inline" onsubmit="return confirm('Regenerate secret? Existing clients must be updated.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('tracking_device_regenerate') }}" />
                    <button type="submit" class="text-xs font-medium px-3 py-1.5 rounded-lg bg-amber-950 text-amber-200 border border-amber-900 hover:bg-amber-900">Regenerate secret</button>
                </form>
            </div>

            <form method="post" action="{{ path('admin_tracking_device_delete', {serverName: server.name, xuid: device.xuid}) }}" class="mt-10 max-w-2xl" onsubmit="return confirm('Delete this device and all its GPS points?');">
                <input type="hidden" name="_token" value="{{ csrf_token('tracking_device_delete') }}" />
                <button type="submit" class="text-xs text-red-400 hover:text-red-300 font-medium">Delete device</button>
            </form>
            {% endif %}
{% endblock %}
