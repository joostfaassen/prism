{% extends 'admin/server_base.html.twig' %}

{% block title %}GPS devices — {{ server.label }}{% endblock %}

{% block server_page_header %}
            <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <div class="flex items-center gap-2 mb-2">
                        <a href="{{ path('admin_tracking_home', {serverName: server.name}) }}" class="text-xs text-slate-500 hover:text-cyan-400 font-mono">GPS</a>
                        <span class="text-slate-600">/</span>
                        <span class="text-xs font-mono text-slate-500">devices</span>
                    </div>
                    <h1 class="text-2xl font-bold text-white">GPS devices</h1>
                    <p class="text-slate-400 text-sm mt-1">Per-device ingest URLs, last GPS ping, and JSON formats for <span class="font-mono text-slate-300">{{ server.name }}</span></p>
                </div>
                <a href="{{ path('admin_tracking_device_new', {serverName: server.name}) }}"
                   class="inline-flex items-center justify-center gap-2 bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors shrink-0">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                    Add device
                </a>
            </div>
{% endblock %}

{% block server_main %}
            {% include 'admin/tracking/_subnav.html.twig' with { trackingSubnav: 'devices' } %}

            {% for message in app.flashes('success') %}
            <div class="mb-6 rounded-xl border border-emerald-800/60 bg-emerald-950/40 px-4 py-3 text-sm text-emerald-200">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
            <div class="mb-6 rounded-xl border border-red-800/60 bg-red-950/40 px-4 py-3 text-sm text-red-200">{{ message }}</div>
            {% endfor %}

            {% if not serverHasTracking %}
            <div class="rounded-2xl border border-amber-800/50 bg-amber-950/20 px-6 py-8 text-center mb-8">
                <p class="text-slate-300 text-sm mb-4">Add a <span class="font-mono text-amber-200/90">tracking</span> account in <code class="text-xs bg-slate-800 px-2 py-1 rounded">prism.config.yaml</code> to enable MCP tools for agents.</p>
                <a href="{{ path('admin_server_tab', {serverName: server.name, tab: 'accounts'}) }}" class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-400 hover:text-cyan-300">View accounts →</a>
            </div>
            {% endif %}

            {% if devices is not empty %}
            <div class="space-y-4">
                {% for d in devices %}
                {% set ping = devicePingInfo[d.xuid] ?? { has_ping: false, since: 'never', last_ping_at: null, seconds_ago: null } %}
                <div class="bg-slate-900 border border-slate-800 rounded-xl px-6 py-5 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                    <div class="flex items-center gap-4 min-w-0">
                        <div class="w-10 h-10 rounded-full border-2 border-slate-700 shrink-0" style="background-color: {{ d.mapColor }}"></div>
                        <div class="min-w-0">
                            <a href="{{ path('admin_tracking_device_edit', {serverName: server.name, xuid: d.xuid}) }}" class="text-sm font-semibold text-white hover:text-cyan-300">{{ d.label }}</a>
                            <p class="text-xs font-mono text-slate-500 mt-1 truncate">{{ ingestBaseUrl }}{{ d.slug }}</p>
                            <p class="text-[11px] text-slate-600 mt-1">Format: <span class="font-mono text-slate-400">{{ d.postFormatPreset }}</span></p>
                            <div class="mt-2 flex flex-wrap items-center gap-2 text-xs">
                                <span class="text-slate-500 font-mono uppercase tracking-wider text-[10px]">Last ping</span>
                                {% if ping.has_ping %}
                                <time datetime="{{ ping.last_ping_at }}" class="text-slate-400 font-mono text-[11px]" title="{{ ping.last_ping_at }}">{{ ping.last_ping_at }}</time>
                                <span class="inline-flex items-center px-2 py-0.5 rounded-md font-medium
                                    {% if ping.seconds_ago > 86400 %}bg-amber-950/60 text-amber-200 border border-amber-900/50
                                    {% elseif ping.seconds_ago > 3600 %}bg-slate-800 text-slate-300 border border-slate-700
                                    {% else %}bg-emerald-950/50 text-emerald-200 border border-emerald-900/40{% endif %}">
                                    {{ ping.since }}
                                </span>
                                {% else %}
                                <span class="text-amber-200/90 bg-amber-950/30 border border-amber-900/40 px-2 py-0.5 rounded-md font-medium">No pings yet</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    <div class="flex flex-wrap gap-2 shrink-0">
                        <a href="{{ path('admin_tracking_device_edit', {serverName: server.name, xuid: d.xuid}) }}" class="text-xs font-medium px-3 py-1.5 rounded-lg bg-slate-800 text-slate-300 hover:text-white border border-slate-700">Edit</a>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="text-center py-16 rounded-2xl border border-slate-800 bg-slate-900/50">
                <p class="text-slate-400 text-sm mb-4">No devices yet. Create one to get an ingest URL and secret.</p>
                <a href="{{ path('admin_tracking_device_new', {serverName: server.name}) }}" class="inline-flex items-center gap-2 bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold px-5 py-2.5 rounded-xl">Add device</a>
            </div>
            {% endif %}
{% endblock %}
