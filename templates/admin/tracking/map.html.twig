{% extends 'admin/server_base.html.twig' %}

{% block title %}GPS map — {{ server.label }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
{% endblock %}

{% block server_page_header %}
            <div class="mb-8">
                <div class="flex items-center gap-2 mb-2">
                    <a href="{{ path('admin_tracking_home', {serverName: server.name}) }}" class="text-xs text-slate-500 hover:text-cyan-400 font-mono">GPS</a>
                    <span class="text-slate-600">/</span>
                    <span class="text-xs font-mono text-slate-500">map</span>
                </div>
                <h1 class="text-2xl font-bold text-white">GPS traces</h1>
                <p class="text-slate-400 text-sm mt-1">OpenStreetMap via Leaflet · calendar day in <span class="font-mono text-slate-300">{{ timezoneName }}</span></p>
            </div>
{% endblock %}

{% block server_main %}
            {% include 'admin/tracking/_subnav.html.twig' with { trackingSubnav: 'map' } %}

            {% for message in app.flashes('success') %}
            <div class="mb-6 rounded-xl border border-emerald-800/60 bg-emerald-950/40 px-4 py-3 text-sm text-emerald-200">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
            <div class="mb-6 rounded-xl border border-red-800/60 bg-red-950/40 px-4 py-3 text-sm text-red-200">{{ message }}</div>
            {% endfor %}

            <form method="get" action="{{ path('admin_tracking_map', {serverName: server.name}) }}" class="mb-6 flex flex-col gap-4 lg:flex-row lg:flex-wrap lg:items-end">
                <div>
                    <label class="block text-xs text-slate-500 mb-1 font-mono">Date</label>
                    <input type="date" name="date" value="{{ traceDate|e('html_attr') }}" class="bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-white font-mono" />
                </div>
                <div class="flex-1 min-w-0">
                    <span class="block text-xs text-slate-500 mb-1 font-mono">Devices</span>
                    <div class="flex flex-wrap gap-3">
                        {% for d in devices %}
                        <label class="inline-flex items-center gap-2 text-sm text-slate-300 cursor-pointer">
                            <input type="checkbox" name="devices[]" value="{{ d.xuid }}"
                                   class="rounded border-slate-600 bg-slate-800 text-cyan-600 focus:ring-cyan-600"
                                   {% if selectedDeviceXuids is null %}checked{% elseif d.xuid in selectedDeviceXuids %}checked{% endif %} />
                            <span class="inline-block w-2.5 h-2.5 rounded-full shrink-0" style="background:{{ d.mapColor }}"></span>
                            {{ d.label }}
                        </label>
                        {% else %}
                        <span class="text-sm text-slate-500">No devices — <a href="{{ path('admin_tracking_device_new', {serverName: server.name}) }}" class="text-cyan-400 hover:underline">create one</a></span>
                        {% endfor %}
                    </div>
                </div>
                <button type="submit" class="bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold px-5 py-2 rounded-xl h-10">Update map</button>
            </form>

            {# Explicit height: Leaflet needs a sized box; arbitrary Tailwind min() may be absent from compiled CSS. #}
            <div id="map" class="w-full rounded-2xl border border-slate-800 bg-slate-900 leaflet-map-host"></div>
            <p class="text-[11px] text-slate-600 mt-3">Faint circles show geofence radius (locations).</p>

            <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
            <style>
                .leaflet-map-host { height: min(70vh, 560px); min-height: 280px; z-index: 0; }
                .leaflet-map-host .leaflet-tile-container img { max-width: none !important; }
            </style>
            <script>
            (function() {
                const el = document.getElementById('map');
                if (typeof L === 'undefined' || !el) {
                    return;
                }
                const points = {{ tracePointsJson|raw }};
                const zones = {{ zonesJson|raw }};
                const map = L.map(el, { scrollWheelZoom: true });
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
                }).addTo(map);

                (zones || []).forEach(function(z) {
                    L.circle([z.lat, z.lon], {
                        radius: z.radius_m,
                        color: '#64748b',
                        weight: 1,
                        fillColor: '#94a3b8',
                        fillOpacity: 0.12
                    }).addTo(map).bindPopup(z.name);
                });

                const byDevice = {};
                (points || []).forEach(function(p) {
                    const k = p.device_xuid;
                    if (!byDevice[k]) byDevice[k] = { label: p.device_label, color: p.map_color || '#22d3ee', latlngs: [] };
                    byDevice[k].latlngs.push([p.latitude, p.longitude]);
                });

                const bounds = [];
                Object.keys(byDevice).forEach(function(k) {
                    const g = byDevice[k];
                    if (g.latlngs.length === 0) return;
                    const pl = L.polyline(g.latlngs, { color: g.color, weight: 3, opacity: 0.85 }).addTo(map);
                    pl.bindPopup(g.label + ' (' + g.latlngs.length + ' pts)');
                    g.latlngs.forEach(function(ll) { bounds.push(ll); });
                });

                if (bounds.length > 0) {
                    map.fitBounds(bounds, { padding: [40, 40], maxZoom: 16 });
                } else {
                    map.setView([20, 0], 2);
                }

                requestAnimationFrame(function() {
                    map.invalidateSize();
                    setTimeout(function() { map.invalidateSize(); }, 250);
                });
            })();
            </script>
{% endblock %}
