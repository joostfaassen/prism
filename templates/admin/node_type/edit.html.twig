{% extends 'admin/server_base.html.twig' %}

{% block title %}{{ nodeType ? 'Edit' : 'New' }} node type — {{ server.label }}{% endblock %}

{% block server_page_header %}
            <div class="mb-8">
                <div class="flex items-center gap-2 mb-3">
                    <a href="{{ path('admin_server_node_types', {serverName: server.name}) }}" class="text-xs text-slate-500 hover:text-cyan-400 transition-colors font-mono flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
                        Node Types
                    </a>
                </div>
                <h1 class="text-2xl font-bold text-white">{{ nodeType ? 'Edit node type' : 'New node type' }}</h1>
                {% if nodeType %}
                <p class="text-xs text-slate-600 font-mono mt-1">{{ nodeType.xuid }}</p>
                {% endif %}
            </div>
{% endblock %}

{% block server_main %}
            {% if errors is not empty %}
            <div class="mb-6 bg-red-950 border border-red-800 rounded-xl px-5 py-4">
                {% for error in errors %}
                <p class="text-sm text-red-300">{{ error }}</p>
                {% endfor %}
            </div>
            {% endif %}

            {% for flash in app.flashes('error') %}
            <div class="mb-6 bg-red-950 border border-red-800 rounded-xl px-5 py-4">
                <p class="text-sm text-red-300">{{ flash }}</p>
            </div>
            {% endfor %}

            <div class="space-y-6 max-w-2xl">
                <form method="post" class="space-y-6">
                <div class="bg-slate-900 rounded-2xl p-8 border border-slate-800 space-y-6">
                    <div>
                        <label for="name" class="block text-sm font-medium text-slate-300 mb-2">Name</label>
                        <input type="text" id="name" name="name"
                               value="{{ formData.name|default(nodeType ? nodeType.name : '') }}"
                               required
                               class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors"
                               placeholder="e.g. Contact, Location, Project">
                    </div>

                    <div>
                        <label for="description" class="block text-sm font-medium text-slate-300 mb-2">Description</label>
                        <textarea id="description" name="description" rows="3"
                                  class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors resize-y"
                                  placeholder="What kind of entities does this type represent?">{{ formData.description|default(nodeType ? nodeType.description : '') }}</textarea>
                    </div>

                    <div>
                        <label for="schema" class="block text-sm font-medium text-slate-300 mb-2">Schema <span class="text-slate-600 font-normal">(YAML)</span></label>
                        <textarea id="schema" name="schema" rows="10"
                                  class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-sm text-cyan-300 placeholder-slate-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors resize-y font-mono"
                                  placeholder="fields:&#10;  phone:&#10;    type: string&#10;  tags:&#10;    type: list">{{ formData.schema|default(nodeType ? nodeType.schema : '') }}</textarea>
                        <p class="mt-1.5 text-xs text-slate-600">Defines the expected config structure for nodes of this type.</p>
                    </div>
                </div>

                <div class="flex items-center gap-3">
                    <button type="submit"
                            class="inline-flex items-center gap-2 bg-cyan-600 hover:bg-cyan-500 text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                        {{ nodeType ? 'Save Changes' : 'Create Type' }}
                    </button>
                    <a href="{{ path('admin_server_node_types', {serverName: server.name}) }}"
                       class="text-sm text-slate-400 hover:text-slate-200 transition-colors px-4 py-2.5">Cancel</a>
                </div>
                </form>

                {% if nodeType %}
                <form method="post" action="{{ path('admin_node_type_delete', {serverName: server.name, xuid: nodeType.xuid}) }}" class="mt-4"
                      onsubmit="return confirm('Delete node type {{ nodeType.name|e('js') }}? This cannot be undone.')">
                    <button type="submit"
                            class="inline-flex items-center gap-2 text-sm text-red-400 hover:text-red-300 transition-colors px-4 py-2.5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>
                        Delete type
                    </button>
                </form>
                {% endif %}
            </div>
{% endblock %}
