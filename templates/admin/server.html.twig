{% extends 'admin/server_base.html.twig' %}

{% block title %}{{ server.label }} — {{ activeSection|capitalize }}{% endblock %}

{% block server_page_header %}
            <div class="mb-8">
                <div class="flex items-center gap-2 mb-3">
                    <a href="{{ path('admin_dashboard') }}" class="text-xs text-slate-500 hover:text-cyan-400 transition-colors font-mono flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
                        All servers
                    </a>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet-600 to-cyan-600 flex items-center justify-center">
                        <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" />
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-3xl font-bold text-white">{{ server.label }}</h1>
                        <p class="text-slate-400 text-sm">{{ server.accountCount }} account{{ server.accountCount != 1 ? 's' : '' }} &middot; {{ server.toolCount }} tool{{ server.toolCount != 1 ? 's' : '' }}</p>
                    </div>
                </div>
            </div>
{% endblock %}

{% block server_main %}
            {# ──── Configuration ──── #}
            {% if activeSection == 'configuration' %}
            <div class="space-y-6">
                <div class="bg-slate-900 rounded-2xl p-8 border border-slate-800">
                    <h2 class="text-sm font-semibold text-cyan-400 uppercase tracking-wider mb-6 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>
                        Connection
                    </h2>
                    <div class="grid gap-6 sm:grid-cols-2">
                        <div>
                            <label class="block text-xs text-slate-500 mb-2 font-mono">MCP Endpoint</label>
                            <code class="block text-sm text-cyan-300 bg-slate-800 rounded-lg px-4 py-3 font-mono break-all">{{ server.mcpUrl }}</code>
                        </div>
                        <div>
                            <label class="block text-xs text-slate-500 mb-2 font-mono">Auth Header</label>
                            <code class="block text-sm text-blue-300 bg-slate-800 rounded-lg px-4 py-3 font-mono">Authorization: Bearer &lt;token&gt;</code>
                        </div>
                    </div>
                    <div class="mt-6">
                        <label class="block text-xs text-slate-500 mb-2 font-mono">Cursor .mcp.json</label>
                        <pre class="text-sm text-emerald-300 bg-slate-800 rounded-lg px-4 py-3 font-mono overflow-x-auto">{
  "mcpServers": {
    "{{ server.name }}": {
      "url": "{{ server.mcpUrl }}",
      "headers": {
        "Authorization": "Bearer YOUR_TOKEN_HERE"
      }
    }
  }
}</pre>
                    </div>
                </div>

                {% if serverHasHabits|default(false) %}
                <div class="mt-6 rounded-xl border border-cyan-900/50 bg-cyan-950/20 px-5 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                    <p class="text-sm text-slate-300">Habit users, goals, REST ingest, and check-ins for this server.</p>
                    <a href="{{ path('admin_server_habits', {serverName: server.name}) }}" class="inline-flex items-center justify-center gap-2 shrink-0 text-sm font-semibold text-cyan-200 bg-cyan-900/50 hover:bg-cyan-800/60 border border-cyan-800/60 px-4 py-2 rounded-lg transition-colors">Open Habits</a>
                </div>
                {% endif %}
            </div>
            {% endif %}

            {# ──── Accounts ──── #}
            {% if activeSection == 'accounts' %}
                {% if server.accountsByType is not empty %}
                <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3">
                    {% for type, accounts in server.accountsByType %}
                    <div class="bg-slate-900 rounded-2xl p-6 border border-slate-800">
                        <div class="flex items-center gap-3 mb-5">
                            <span class="font-mono text-xs font-semibold text-violet-300 bg-violet-950 px-3.5 py-1.5 rounded-lg uppercase tracking-wider">{{ type }}</span>
                            <span class="text-xs text-slate-500 font-mono">&times; {{ accounts|length }}</span>
                        </div>
                        <ul class="space-y-3">
                            {% for account in accounts %}
                            <li class="flex items-center gap-3 bg-slate-800 rounded-lg px-4 py-3">
                                <span class="w-2 h-2 bg-cyan-400 rounded-full flex-shrink-0"></span>
                                <div class="min-w-0 flex-1">
                                    <span class="block text-sm text-slate-200 truncate" title="{{ account.name }}">{{ account.label }}</span>
                                    <span class="block text-xs text-slate-500 font-mono mt-0.5">{{ account.name }}</span>
                                </div>
                            </li>
                            {% endfor %}
                        </ul>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <div class="text-center py-16 text-slate-500">
                    <p class="text-sm">No accounts configured for this server.</p>
                </div>
                {% endif %}
            {% endif %}

            {# ──── Tools ──── #}
            {% if activeSection == 'tools' %}
                {% if server.tools is not empty %}
                <div class="space-y-3">
                    {% for tool in server.tools %}
                    <a href="{{ path('admin_tool_detail', {serverName: server.name, toolName: tool.name}) }}"
                       class="group flex items-center justify-between bg-slate-900 border border-slate-800 hover:border-cyan-800 rounded-xl px-6 py-4 transition-all duration-200 hover:bg-slate-900 hover:bg-opacity-80">
                        <div class="flex items-center gap-4 min-w-0">
                            <div class="w-10 h-10 rounded-lg bg-cyan-950 flex items-center justify-center flex-shrink-0">
                                <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" />
                                </svg>
                            </div>
                            <div class="min-w-0">
                                <span class="block text-sm font-semibold text-white font-mono group-hover:text-cyan-300 transition-colors">{{ tool.name }}</span>
                                <p class="text-xs text-slate-500 truncate mt-0.5">{{ tool.description }}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3 flex-shrink-0 ml-4">
                            {% if tool.accountType %}
                            <span class="text-xs font-mono font-semibold text-violet-300 bg-violet-950 px-3 py-1.5 rounded-lg">{{ tool.accountType }}</span>
                            {% endif %}
                            <svg class="w-4 h-4 text-slate-600 group-hover:text-cyan-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                            </svg>
                        </div>
                    </a>
                    {% endfor %}
                </div>
                {% else %}
                <div class="text-center py-16 text-slate-500">
                    <p class="text-sm">No tools available for this server.</p>
                </div>
                {% endif %}
            {% endif %}

            {# ──── Agent notify ──── #}
            {% if activeSection == 'agents' %}
            <div class="max-w-3xl space-y-6">
                <div class="bg-slate-900 rounded-2xl p-8 border border-slate-800">
                    <h2 class="text-sm font-semibold text-cyan-400 uppercase tracking-wider mb-2 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1 5.848 12.12 14.926 14.926 0 0 1-5.848 12.12" /></svg>
                        External agent webhook
                    </h2>
                    <p class="text-sm text-slate-400 mb-6 leading-relaxed">
                        One <code class="text-cyan-300/90 font-mono text-xs">agent_notify</code> block per server in <code class="text-cyan-300/90 font-mono text-xs">prism.config.yaml</code>.
                        Use <code class="text-violet-300 font-mono text-xs">openclaw</code> for OpenClaw gateway hooks (e.g. <code class="font-mono text-xs">/hooks/agent</code>), or <code class="text-violet-300 font-mono text-xs">webhook</code> for a generic JSON POST (<code class="font-mono text-xs">message</code> + <code class="font-mono text-xs">context</code>).
                    </p>
                    {% if server.agentNotifyConfigured %}
                    <dl class="grid gap-3 sm:grid-cols-2 text-sm mb-8">
                        <div>
                            <dt class="text-xs text-slate-500 font-mono mb-1">Type</dt>
                            <dd class="text-slate-200 font-mono">{{ server.agentNotifyType }}</dd>
                        </div>
                        <div>
                            <dt class="text-xs text-slate-500 font-mono mb-1">Endpoint</dt>
                            <dd class="text-slate-200 font-mono break-all text-xs">{{ server.agentNotifyEndpointHint }}</dd>
                        </div>
                    </dl>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-xs text-slate-500 mb-2 font-mono" for="agent-notify-message">Message (sent to the agent)</label>
                            <textarea id="agent-notify-message" rows="4"
                                class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-sm text-cyan-100 font-mono placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 resize-y"
                                placeholder="Leave empty for a default test message."
                                spellcheck="false"></textarea>
                        </div>
                        <div class="flex items-center gap-3 flex-wrap">
                            <button type="button" id="agent-notify-btn"
                                class="px-6 py-2.5 bg-gradient-to-r from-violet-600 to-cyan-600 hover:from-violet-500 hover:to-cyan-500 text-white text-sm font-semibold rounded-lg shadow-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-cyan-400 flex items-center gap-2 cursor-pointer">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" /></svg>
                                Trigger agent
                            </button>
                            <span id="agent-notify-status" class="text-xs font-mono text-slate-600 hidden"></span>
                        </div>
                        <div id="agent-notify-result-wrap" class="hidden">
                            <label class="block text-xs text-slate-500 mb-2 font-mono">Result</label>
                            <pre id="agent-notify-result" class="text-xs bg-slate-800 rounded-lg px-4 py-3 font-mono overflow-x-auto whitespace-pre-wrap max-h-80 overflow-y-auto text-slate-200 border border-slate-700"></pre>
                        </div>
                    </div>
                    {% else %}
                    <div class="rounded-xl border border-amber-900/60 bg-amber-950/20 px-5 py-4 text-sm text-amber-200/90">
                        <p class="font-medium text-amber-100 mb-2">Not configured</p>
                        <pre class="text-[11px] leading-relaxed font-mono text-amber-200/90 whitespace-pre-wrap overflow-x-auto">servers:
  {{ server.name }}:
    # …
    agent_notify:
      type: openclaw
      webhook_url: "https://your-gateway/hooks/agent"
      bearer_token: "your-hook-token"
      agent_id: hooks
      channel: last
      deliver: true</pre>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% if server.agentNotifyConfigured %}
            <script>
            (function() {
                var btn = document.getElementById('agent-notify-btn');
                var msg = document.getElementById('agent-notify-message');
                var statusEl = document.getElementById('agent-notify-status');
                var wrap = document.getElementById('agent-notify-result-wrap');
                var out = document.getElementById('agent-notify-result');
                var url = {{ server.agentNotifyTriggerUrl|json_encode|raw }};
                btn.addEventListener('click', function() {
                    btn.disabled = true;
                    btn.classList.add('opacity-60');
                    statusEl.textContent = 'Calling webhook…';
                    statusEl.classList.remove('hidden', 'text-red-400', 'text-emerald-400');
                    statusEl.classList.add('text-slate-400');
                    fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: (msg.value || '').trim() })
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        wrap.classList.remove('hidden');
                        out.textContent = JSON.stringify(data, null, 2);
                        if (data.success) {
                            statusEl.textContent = 'HTTP ' + (data.http_status || '?');
                            statusEl.classList.remove('text-slate-400');
                            statusEl.classList.add('text-emerald-400');
                        } else {
                            statusEl.textContent = 'Failed';
                            statusEl.classList.remove('text-slate-400');
                            statusEl.classList.add('text-red-400');
                        }
                    })
                    .catch(function(err) {
                        wrap.classList.remove('hidden');
                        out.textContent = JSON.stringify({ error: err.message }, null, 2);
                        statusEl.textContent = 'Network error';
                        statusEl.classList.remove('hidden');
                        statusEl.classList.remove('text-slate-400');
                        statusEl.classList.add('text-red-400');
                    })
                    .finally(function() {
                        btn.disabled = false;
                        btn.classList.remove('opacity-60');
                    });
                });
            })();
            </script>
            {% endif %}
            {% endif %}

            {# ──── Audit ──── #}
            {% if activeSection == 'audit' %}
            <div class="text-center py-20">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-slate-800 mb-4">
                    <svg class="w-8 h-8 text-slate-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-slate-400 mb-2">Audit Log</h3>
                <p class="text-sm text-slate-600 max-w-md mx-auto">Request and response logging will appear here. This feature is planned for a future release.</p>
            </div>
            {% endif %}
{% endblock %}
